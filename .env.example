# --- LLM engine selection ---
# Which model backend the AI routes use (see src/lib/llm). Unset/"auto" → Gemini
# when GEMINI_API_KEY is set, otherwise the deterministic template fallback. Set
# "claude" to use the Claude Code CLI with your LOCAL subscription login — handy
# for rapid local dev/testing with no API key or per-token billing.
#   • LOCAL-ONLY: there is no interactive login on Cloud Run.
#   • Does NOT handle image/multimodal operations (those force Gemini).
LLM_ENGINE=                     # (empty)|auto | gemini | claude
CLAUDE_CLI_PATH=claude          # path/name of the Claude Code CLI binary
CLAUDE_CLI_MODEL=sonnet         # sonnet | haiku | opus | full model id

# --- Gemini / Vertex AI ---
# Leave GEMINI_API_KEY empty (and LLM_ENGINE unset) to run fully offline: the AI
# routes return deterministic, templated output (with the not-legal-advice
# disclaimer) so the app builds and runs with NO secret. Set a key to call the
# real model. NEVER commit a real key — .env*.local / .env are gitignored.
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=./.gcp/key.json
# Fast model for short/structured ops (guidance, qualify, categorize).
GEMINI_MODEL=gemini-3-flash-preview
# Long-context model for full petition / RFE drafting (falls back to GEMINI_MODEL).
GEMINI_DRAFT_MODEL=

# --- Document AI (evidence OCR) ---
DOCAI_PROCESSOR_ID=
DOCAI_LOCATION=us

# --- Voice intake agent ---
VAPI_API_KEY=
RETELL_API_KEY=

# --- Token economy + Polar paywall (Procedure 2) ---
# All empty by default → ledger/grant/debit/paywall still work; only real
# PURCHASES need Polar. Set after creating the bundle products in Polar.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox            # sandbox | production
POLAR_PRODUCT_STARTER=          # product id for the 500-token bundle
POLAR_PRODUCT_BUILDER=          # 2,000-token bundle
POLAR_PRODUCT_PRO=              # 8,000-token bundle
POLAR_PRODUCT_SCALE=            # 30,000-token bundle
NEXT_PUBLIC_ENTERPRISE_CONTACT=mailto:sales@example.com

# Dev/test only — 1 = bypass the paywall so AI runs unmetered (no Polar, no
# balance needed); also enables POST /api/dev/grant-tokens. Leave empty in prod.
TOKENS_BYPASS=

# --- Legacy subscription billing (retired; replaced by the token economy) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- Attorney review & filing (workflow) ---
# Comma-separated emails allowed to act as the attorney of record (review queue,
# request-changes, sign & file, record decision). LEAVE EMPTY in dev to unlock
# the attorney actions for everyone (graceful demo default); set in production
# to restrict them to your licensed attorney(s).
ATTORNEY_EMAILS=

# --- E-sign / attorney sign-off ---
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=

# --- Supabase auth (Procedure 1 — Google OAuth, gating & first-auth consent) ---
# Public (browser) — note the NEXT_PUBLIC_ prefix. Copy the values from the
# shared project's SUPABASE_URL / SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_CONSENT_VERSION=2026-05-29

# Server only — never commit real values (.env*.local / .env are git-ignored).
# This app's PRIVATE Postgres schema (already created, not exposed to PostgREST).
APP_AUTH_SCHEMA=app_immigration
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# DATABASE_URL is the direct Postgres connection for this app's private schema.
# For production serverless use the transaction pooler (port 6543,
# *.pooler.supabase.com) to avoid exhausting connections.
DATABASE_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ATTORNEY_FIRM_NAME=
NEXT_PUBLIC_ATTORNEY_BAR_STATE=
