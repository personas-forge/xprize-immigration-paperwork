# --- Gemini / Vertex AI ---
# Leave GEMINI_API_KEY empty to run fully offline: /api/guidance returns
# deterministic, templated informational guidance (with the not-legal-advice
# disclaimer) so the app builds and runs with NO secret. Set a key to call the
# real model (gemini-3.5-flash) from src/app/api/guidance/route.ts.
# NEVER commit a real key — .env*.local / .env are gitignored.
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=./.gcp/key.json
# GEMINI_MODEL is informational only — the route pins gemini-3.5-flash.
GEMINI_MODEL=gemini-3.5-flash

# --- Document AI (evidence OCR) ---
DOCAI_PROCESSOR_ID=
DOCAI_LOCATION=us

# --- Voice intake agent ---
VAPI_API_KEY=
RETELL_API_KEY=

# --- Billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- E-sign / attorney sign-off ---
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=

# --- App ---
DATABASE_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ATTORNEY_FIRM_NAME=
NEXT_PUBLIC_ATTORNEY_BAR_STATE=
