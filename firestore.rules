rules_version = '2';

// All app data is accessed SERVER-SIDE via the Firebase Admin SDK, which
// bypasses these rules entirely. Clients (browser firebase/firestore SDK) must
// NEVER read or write Firestore directly — this is the document-DB equivalent
// of the old "private schema, not exposed to PostgREST" rule. So: deny everyone.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
